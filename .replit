modules = ["nodejs-20", "python-3.12", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["freetype", "glibcLocales", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "mongodb", "openjpeg", "pkg-config", "tcl", "tk", "xsimd", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Flask Microservice"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "mongod --dbpath /home/runner/workspace/data/db --port 27017 --bind_ip 127.0.0.1 --fork --logpath /home/runner/workspace/data/mongod.log && sleep 2 && cd backend && NODE_ENV=development PORT=3001 MONGO_URI='mongodb://localhost:27017/cognitive-load' node src/server.js"
waitForPort = 3001

[[workflows.workflow]]
name = "Flask Microservice"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd flask-microservice && python app.py"
waitForPort = 5001

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "mongod --dbpath /home/runner/workspace/data/db --port 27017 --bind_ip 127.0.0.1 --fork --logpath /home/runner/workspace/data/mongod.log && sleep 2 && cd backend && NODE_ENV=production PORT=3001 MONGO_URI='mongodb://localhost:27017/cognitive-load' node src/server.js & cd frontend && npm run build && npx serve -s dist -l 5000"]
